aws_region = "REPLACE_WITH_AWS_REGION"

name_prefix = "iaagents"

vector_index_generations = {
  g001 = {
    active                              = true
    embedding_profile_alias             = "REPLACE_WITH_SERVER_PROFILE_ALIAS"
    embedding_profile_revision          = "REPLACE_WITH_IMMUTABLE_PROFILE_REVISION"
    embedding_dimensions                = 1024
    vector_distance_metric              = "cosine"
    vector_encryption_revision           = "enc-v1"
    vector_non_filterable_metadata_keys = [
      "checksum",
      "chunkId",
      "embeddingDimensions",
      "embeddingModelId",
      "pipelineVersion",
      "sourceVersion",
    ]
  }
}

encryption_mode = "AES256"
create_kms_key  = false
kms_key_arn     = null

tags = {
  CostCenter = "REPLACE_WITH_COST_CENTER"
  Owner      = "REPLACE_WITH_OWNER"
}
